	setAttr ".b" -type "string" "{\nstring $ma_path = `file -q -sn`;\nstring $dir_name = dirname($ma_path);\nfor ( $i = 1; $i <= 5; ++$i) {\n  select -r (bound_\" + (string)$i);\n  string $file_name = ($dir_name + \"/spoon_bound_\" + (string)$i + \".obj\");\n  file -force -options \"groups=0;ptgroups=0;materials=0;smoothing=0;normals=0\" -typ \"OBJexport\" -pr -es $file_name;\n  print ($file_name + \"\\n\");\n}\n}";
